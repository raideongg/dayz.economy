<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<economycore>
    <classes>
        <rootclass name="DefaultWeapon"/>
        <rootclass name="DefaultMagazine"/>
        <rootclass name="Inventory_Base"/>
        <rootclass name="HouseNoDestruct" reportMemoryLOD="no"/>
        <rootclass name="SurvivorBase" act="character" reportMemoryLOD="no"/>
        <rootclass name="DZ_LightAI" act="character" reportMemoryLOD="no"/>
        <rootclass name="CarScript" act="car" reportMemoryLOD="no"/>
        <rootclass name="BoatScript" act="car" reportMemoryLOD="no"/>
    </classes>
    <ce folder="raideon/events">
        <file name="ambient.xml" type="events"/>
        <file name="animals.xml" type="events"/>
        <file name="infected.xml" type="events"/>
        <file name="static.xml" type="events"/>
        <file name="trajectory.xml" type="events"/>
        <file name="vehicles.xml" type="events"/>
    </ce>
    <ce folder="raideon/spawnable">
        <file name="vehicles.xml" type="spawnabletypes"/>
        <file name="zombies.xml" type="spawnabletypes"/>
    </ce>
    <ce folder="raideon/types">
        <file name="ammo.xml" type="types"/>
        <file name="ammobox.xml" type="types"/>
        <file name="animals.xml" type="types"/>
        <file name="containers.xml" type="types"/>
        <file name="crafted.xml" type="types"/>
        <file name="explosives.xml" type="types"/>
        <file name="flags.xml" type="types"/>
        <file name="food.xml" type="types"/>
        <file name="giftboxes.xml" type="types"/>
        <file name="lootdispatch.xml" type="types"/>
        <file name="magazines.xml" type="types"/>
        <file name="static.xml" type="types"/>
        <file name="vehicles.xml" type="types"/>
        <file name="weapons.xml" type="types"/>
        <file name="zombies.xml" type="types"/>
    </ce>
    <defaults>
        <default name="dyn_radius" value="30"/>
        <default name="dyn_smin" value="0"/>
        <default name="dyn_smax" value="0"/>
        <default name="dyn_dmin" value="1"/>
        <default name="dyn_dmax" value="5"/>
        <default name="log_ce_loop" value="false"/>
        <default name="log_ce_dynamicevent" value="false"/>
        <default name="log_ce_vehicle" value="false"/>
        <default name="log_ce_lootspawn" value="false"/>
        <default name="log_ce_lootcleanup" value="false"/>
        <default name="log_ce_lootrespawn" value="false"/>
        <default name="log_ce_statistics" value="false"/>
        <default name="log_ce_zombie" value="false"/>
        <default name="log_storageinfo" value="false"/>
        <default name="log_hivewarning" value="true"/>
        <default name="log_missionfilewarning" value="true"/>
        <default name="save_events_startup" value="true"/>
        <default name="save_types_startup" value="true"/>
    </defaults>
</economycore>
